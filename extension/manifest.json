{
  "manifest_version": 3,
  "name": "Test Combine",
  "version": "2.0",
  "description": "Kết hợp Highlight từ vựng và Dịch chèn dòng",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies",
    "tabs"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_globs": ["*pdfjs/web/viewer.html*"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}