{
  "manifest_version": 3,
  "name": "Test Combine",
  "version": "2.0",
  "description": "Kết hợp Highlight từ vựng và Dịch chèn dòng",
  "permissions": [
    "storage",
    "activeTab",
    "scripting",
    "cookies"
  ],
  "host_permissions": [
    "http://localhost:8000/*",
    "http://localhost:3000/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "css": ["styles.css"],
      "js": ["content.js"]
    }
  ]
}